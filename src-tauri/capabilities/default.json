{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for SimplShot",
  "windows": ["main", "editor"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:app:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "notification:default",
    "notification:allow-request-permission",
    "notification:allow-send-notification",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-create",
    "store:default",
    "shell:default"
  ]
}
